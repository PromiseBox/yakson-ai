# 데이터 소스: mock(기본, 키 불필요) | mfds(식약처 실 API) | pg(yaksok_db Cloud SQL)
DATA_SOURCE=mock

# DATA_SOURCE=pg 일 때 (cloud-sql-proxy 로 127.0.0.1:55432 터널 후 사용). 비번은 절대 커밋 금지.
# YAKSOK_DB_HOST=127.0.0.1
# YAKSOK_DB_PORT=55432
# YAKSOK_DB_NAME=yakson
# YAKSOK_DB_USER=<본인>_readonly
# YAKSOK_DB_PASSWORD=

# 식약처 공공데이터포털 활용신청 후 발급받는 서비스키 (DATA_SOURCE=mfds 일 때 필요)
# https://www.data.go.kr 에서 'DUR품목정보', 'e약은요' 활용신청
MFDS_SERVICE_KEY=

# comm 단계 자연어 다듬기: template(기본) | claude | gemini | openai
LLM_PROVIDER=template
ANTHROPIC_API_KEY=
