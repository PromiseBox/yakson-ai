# Local Cloud SQL Proxy example
# Run Cloud SQL Auth Proxy locally, then point FastAPI at the proxy port.
DATABASE_URL=postgresql+psycopg://DB_USER:DB_PASSWORD@127.0.0.1:55432/yakson
DATABASE_SCHEMA=yakson
DATABASE_AUTO_CREATE=false
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# Comma-separated frontend origins allowed by FastAPI CORS.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production examples:
# DATABASE_URL=postgresql+psycopg://DB_USER:DB_PASSWORD@DB_HOST:5432/yakson
# DATABASE_URL=postgresql+psycopg://DB_USER:DB_PASSWORD@/yakson?host=/cloudsql/PROJECT:REGION:INSTANCE
