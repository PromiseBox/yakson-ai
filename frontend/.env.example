# Browser-side API calls use Next.js API routes by default.
# Keep this empty unless the browser should call FastAPI directly.
NEXT_PUBLIC_API_BASE_URL=

# Server-side Next.js route handlers proxy requests to FastAPI.
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# Must match backend BACKEND_SHARED_SECRET in production. It is only used by
# Next.js server-side route handlers and is never exposed through NEXT_PUBLIC_*.
BACKEND_SHARED_SECRET=
